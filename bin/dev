#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=bin/_common.sh
source "$SCRIPT_DIR/_common.sh"

require_ruby_tools
require_bundle_dependencies

cd "$ROOT_DIR"
exec bundle exec jekyll serve --drafts --config _config.yml,_config.dev.yml
