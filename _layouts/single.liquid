---
layout: default
---
{% assign year = page.date | date: '%Y' %}
{% assign tags = page.tags | join: '' %}
{% assign categories = page.categories | join: '' %}
{% assign url_beginning = page.url | slice: 0, 6 %}
{% assign read_time = content | number_of_words | divided_by: 180 | plus: 1 %}

{% if page._styles %}
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="essay-page post">
  <header class="essay-hero">
    <div class="essay-hero-kicker">
      <a href="{{ '/blog/' | relative_url }}">Blog</a>
      <span>{{ page.date | date: '%B %d, %Y' }}</span>
      <span>{{ read_time }} min read</span>
      {% if page.lang %}<span class="essay-lang">{{ page.lang | upcase }}</span>{% endif %}
    </div>

    <h1 class="essay-title">{{ page.title }}</h1>

    {% if page.description %}
      <p class="essay-subtitle">{{ page.description }}</p>
    {% endif %}

    <div class="essay-taxonomy">
      {% if url_beginning == '/blog/' %}
        <a href="{{ year | prepend: '/blog/' | relative_url }}"><i class="fa-solid fa-calendar fa-sm"></i> {{ year }}</a>
      {% else %}
        <span><i class="fa-solid fa-calendar fa-sm"></i> {{ year }}</span>
      {% endif %}

      {% if tags != '' %}
        {% for tag in page.tags %}
          {% if url_beginning == '/blog/' %}
            <a href="{{ tag | slugify | prepend: '/blog/tag/' | relative_url }}">#{{ tag }}</a>
          {% else %}
            <span>#{{ tag }}</span>
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
  </header>

  <div class="essay-shell">
    <aside class="essay-sidebar" aria-label="Article navigation">
      <div class="essay-sidebar-inner">
        <div class="essay-sidebar-label">In this essay</div>
        <nav class="essay-toc">
          {% toc %}
        </nav>
        <div class="essay-sidebar-actions">
          <a href="{{ '/blog/' | relative_url }}">← All posts</a>
          {% if page.lang == 'zh' %}
            <a href="{{ '/blog/2026/next-gen-agent-en/' | relative_url }}">English version</a>
          {% elsif page.lang == 'en' %}
            <a href="{{ '/blog/2026/next-gen-agent-zh/' | relative_url }}">中文版</a>
          {% endif %}
        </div>
      </div>
    </aside>

    <article class="essay-article post-content">
      <div id="markdown-content">
        {{ content }}
      </div>
    </article>
  </div>

  {% if page.citation %}
    {% include citation.liquid %}
  {% endif %}

  {% if page.related_publications %}
    <h2>References</h2>
    <div class="publications">
      {% bibliography --group_by none --cited_in_order %}
    </div>
  {% endif %}

  {% if site.related_blog_posts and site.related_blog_posts.enabled %}
    {% if page.related_posts == null or page.related_posts %}
      {% include related_posts.liquid %}
    {% endif %}
  {% endif %}
</div>
